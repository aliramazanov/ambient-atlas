{
  "name": "ambient-atlas",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "author": {
    "name": "Ali Ramazanov"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "check:citations": "node --experimental-strip-types scripts/check/citations.ts",
    "data:places": "node --experimental-strip-types scripts/generate/places.ts",
    "data:life": "node --experimental-strip-types scripts/generate/life-expectancy.ts",
    "data:citylife": "node --experimental-strip-types scripts/generate/city-life-expectancy.ts",
    "data:indicators": "node --experimental-strip-types scripts/generate/indicators.ts",
    "data:livable": "node --experimental-strip-types scripts/generate/livable.ts",
    "data:citydata": "node --experimental-strip-types scripts/generate/citydata.ts",
    "data:build": "pnpm data:places && pnpm data:life && pnpm data:citylife && pnpm data:indicators && pnpm data:livable && pnpm data:citydata",
    "zones:insert": "node --experimental-strip-types scripts/zones/insert.ts",
    "zones:qa": "node --experimental-strip-types scripts/zones/qa.ts",
    "zones:sync": "pnpm data:citydata && pnpm data:livable"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/three": "^0.184.1",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "all-the-cities": "^3.1.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "world-countries": "^5.1.0"
  },
  "dependencies": {
    "@threlte/core": "^8.5.16",
    "@threlte/extras": "^9.21.0",
    "d3-geo": "^3.1.1",
    "three": "^0.185.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  }
}
